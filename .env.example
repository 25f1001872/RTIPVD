# ==============================================================
# RTIPVD — Environment Variables Template
# ==============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are loaded by the application at runtime.
# ==============================================================

# Device selection
DEVICE=cuda:0

# Video source (path to video file or camera index)
VIDEO_SOURCE=data/videos/d1.mp4

# Phase 2: Google Maps API Key (for map overlay)
# GOOGLE_MAPS_API_KEY=your_api_key_here

# Phase 2: Database
# DB_PATH=output/db/rtipvd.db